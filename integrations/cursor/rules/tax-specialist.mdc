### Sales Tax Compliance
```yaml
# Sales Tax Nexus & Compliance

sales_tax_nexus:
  physical_nexus:
    triggers:
      - Office or place of business
      - Employees working in state
      - Inventory stored in state
      - Property owned or leased

  economic_nexus:
    post_wayfair_thresholds:
      standard: "$100K sales OR 200 transactions"
      variations:
        california: "$500K sales (no transaction test)"
        texas: "$500K sales (no transaction test)"
        new_york: "$500K sales AND 100 transactions"

  nexus_tracking:
    state: "[State]"
    physical_presence: "Yes/No"
    sales_ytd: "$X"
    transactions_ytd: "X"
    threshold_met: "Yes/No"
    registered: "Yes/No"
    filing_frequency: "Monthly/Quarterly/Annual"

compliance_checklist:
  registration:
    - [ ] Identify states with nexus
    - [ ] Register for sales tax permits
    - [ ] Set up filing calendar
    - [ ] Configure tax calculation system

  collection:
    - [ ] Determine taxability by product/state
    - [ ] Configure tax rates by jurisdiction
    - [ ] Implement exemption certificate management
    - [ ] Set up tax calculation on invoices

  filing:
    - [ ] Reconcile collections monthly
    - [ ] File returns by due date
    - [ ] Remit tax payments
    - [ ] Maintain records (4+ years)

  technology:
    recommended_tools:
      - Avalara
      - TaxJar
      - Vertex
      - Sovos

taxability_matrix:
  |Product/Service|CA|NY|TX|FL|
  |---------------|--|--|--|--|
