# Advanced demand forecasting with multiple methods
import pandas as pd
import numpy as np
from scipy import stats
from dataclasses import dataclass
from typing import Dict, List, Tuple
from datetime import datetime, timedelta

@dataclass
class ForecastResult:
    sku: str
    forecast_date: datetime
    predicted_demand: float
    confidence_interval: Tuple[float, float]
    method_used: str
    accuracy_score: float

class DemandForecaster:
    def __init__(self):
        self.methods = ['moving_average', 'exponential_smoothing', 'seasonal']

    def forecast(
        self,
        historical_data: pd.DataFrame,
        forecast_horizon: int = 30
    ) -> List[ForecastResult]:
        """Generate demand forecast using best-fit method"""

        results = []

        for sku in historical_data['sku'].unique():
            sku_data = historical_data[historical_data['sku'] == sku].copy()
            sku_data = sku_data.sort_values('date')

            # Try each method and select best
            best_method = None
            best_accuracy = 0
            best_forecast = None

            for method in self.methods:
                forecast, accuracy = self._apply_method(method, sku_data)
                if accuracy > best_accuracy:
                    best_accuracy = accuracy
                    best_method = method
                    best_forecast = forecast

            # Generate confidence interval
            std_dev = sku_data['quantity'].std()
            ci_lower = max(0, best_forecast - 1.96 * std_dev)
            ci_upper = best_forecast + 1.96 * std_dev

            results.append(ForecastResult(
                sku=sku,
                forecast_date=datetime.now() + timedelta(days=forecast_horizon),
                predicted_demand=best_forecast,
                confidence_interval=(ci_lower, ci_upper),
                method_used=best_method,
                accuracy_score=best_accuracy
            ))

        return results

    def _apply_method(
        self,
        method: str,
        data: pd.DataFrame
    ) -> Tuple[float, float]:
        """Apply forecasting method and return forecast with accuracy"""

        values = data['quantity'].values

        if method == 'moving_average':
            window = min(7, len(values))
            forecast = np.mean(values[-window:])

        elif method == 'exponential_smoothing':
            alpha = 0.3
            forecast = values[-1]
            for i, val in enumerate(values[:-1]):
                forecast = alpha * val + (1 - alpha) * forecast

        elif method == 'seasonal':
            # Simple seasonal decomposition
            if len(values) >= 14:
                seasonal_period = 7
                seasonal_indices = []
                for i in range(seasonal_period):
                    indices = values[i::seasonal_period]
                    seasonal_indices.append(np.mean(indices))
                forecast = np.mean(values[-7:]) * (
                    seasonal_indices[datetime.now().weekday()] /
                    np.mean(seasonal_indices)
                )
            else:
                forecast = np.mean(values)

        # Calculate accuracy using holdout
        if len(values) > 10:
            train = values[:-5]
            test = values[-5:]
            # Simple MAPE calculation
            predictions = [forecast] * 5
            mape = np.mean(np.abs((test - predictions) / test))
            accuracy = max(0, 1 - mape)
        else:
            accuracy = 0.5

        return forecast, accuracy


class InventoryOptimizer:
    def __init__(self):
        self.service_level = 0.98  # 98% target in-stock
        self.z_score = stats.norm.ppf(self.service_level)

    def calculate_reorder_point(
        self,
        average_daily_demand: float,
        demand_std_dev: float,
        lead_time_days: int,
        lead_time_variability: float = 0
    ) -> Dict:
        """Calculate optimal reorder point with safety stock"""

        # Average demand during lead time
        lead_time_demand = average_daily_demand * lead_time_days

        # Safety stock calculation (considers both demand and lead time variability)
        demand_variance = (lead_time_days * demand_std_dev ** 2)
        lead_time_variance = (average_daily_demand ** 2 * lead_time_variability ** 2)
        combined_std = np.sqrt(demand_variance + lead_time_variance)

        safety_stock = self.z_score * combined_std

        reorder_point = lead_time_demand + safety_stock

        return {
            'reorder_point': int(np.ceil(reorder_point)),
            'safety_stock': int(np.ceil(safety_stock)),
            'lead_time_demand': int(np.ceil(lead_time_demand)),
            'service_level': self.service_level,
            'daily_demand': average_daily_demand
        }

    def calculate_eoq(
        self,
        annual_demand: float,
        order_cost: float,
        holding_cost_per_unit: float
    ) -> Dict:
        """Calculate Economic Order Quantity"""

        # EOQ formula: sqrt(2 * D * S / H)
        eoq = np.sqrt((2 * annual_demand * order_cost) / holding_cost_per_unit)

        # Number of orders per year
        orders_per_year = annual_demand / eoq

        # Total cost
        ordering_cost = orders_per_year * order_cost
        holding_cost = (eoq / 2) * holding_cost_per_unit
        total_cost = ordering_cost + holding_cost

        return {
            'eoq': int(np.ceil(eoq)),
            'orders_per_year': round(orders_per_year, 1),
            'total_annual_cost': round(total_cost, 2),
            'ordering_cost': round(ordering_cost, 2),
            'holding_cost': round(holding_cost, 2)
        }

    def abc_analysis(self, inventory_data: pd.DataFrame) -> pd.DataFrame:
        """Classify inventory using ABC analysis"""

        # Calculate annual value
        inventory_data['annual_value'] = (
            inventory_data['annual_units'] * inventory_data['unit_cost']
        )

        # Sort by value descending
        inventory_data = inventory_data.sort_values(
            'annual_value', ascending=False
        )

        # Calculate cumulative percentage
        total_value = inventory_data['annual_value'].sum()
        inventory_data['cumulative_pct'] = (
            inventory_data['annual_value'].cumsum() / total_value
        )

        # Assign ABC class
        def classify(pct):
            if pct <= 0.80:
                return 'A'  # Top 80% of value
            elif pct <= 0.95:
                return 'B'  # Next 15% of value
            return 'C'  # Bottom 5% of value

        inventory_data['abc_class'] = inventory_data['cumulative_pct'].apply(classify)

        return inventory_data
