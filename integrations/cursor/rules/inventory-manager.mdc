### Multi-Channel Inventory Allocation
```python
# Inventory allocation across channels and warehouses
from dataclasses import dataclass
from typing import Dict, List
import numpy as np

@dataclass
class Channel:
    name: str
    daily_demand: float
    demand_variability: float
    fulfillment_priority: int  # 1 = highest
    min_stock_days: int

@dataclass
class Warehouse:
    name: str
    current_stock: int
    max_capacity: int
    channels_served: List[str]
    replenishment_lead_time: int

class InventoryAllocator:
    def __init__(self, service_level: float = 0.95):
        self.service_level = service_level
        self.z_score = 1.65  # 95% service level

    def allocate_inventory(
        self,
        total_available: int,
        channels: List[Channel],
        warehouses: List[Warehouse]
    ) -> Dict:
        """Allocate inventory optimally across channels"""

        allocations = {}

        # Sort channels by priority
        sorted_channels = sorted(channels, key=lambda x: x.fulfillment_priority)

        remaining_inventory = total_available

        for channel in sorted_channels:
            # Calculate channel requirement
            safety_stock = self.z_score * channel.demand_variability * np.sqrt(channel.min_stock_days)
            target_stock = (channel.daily_demand * channel.min_stock_days) + safety_stock

            # Allocate what we can
            allocation = min(int(target_stock), remaining_inventory)
            allocations[channel.name] = {
                'allocated': allocation,
                'target': int(target_stock),
                'shortfall': max(0, int(target_stock) - allocation),
                'days_of_stock': allocation / channel.daily_demand if channel.daily_demand > 0 else 999
            }

            remaining_inventory -= allocation

        return {
            'allocations': allocations,
            'unallocated': remaining_inventory,
            'total_shortfall': sum(a['shortfall'] for a in allocations.values())
        }

    def rebalance_inventory(
        self,
        warehouses: List[Warehouse],
        demand_by_warehouse: Dict[str, float]
    ) -> List[Dict]:
        """Generate transfer recommendations to balance inventory"""

        transfers = []

        # Calculate days of stock per warehouse
        warehouse_status = []
        for wh in warehouses:
            demand = demand_by_warehouse.get(wh.name, 0)
            days_of_stock = wh.current_stock / demand if demand > 0 else 999
            warehouse_status.append({
                'warehouse': wh,
                'days_of_stock': days_of_stock,
                'demand': demand
            })

        # Sort by days of stock
        warehouse_status.sort(key=lambda x: x['days_of_stock'])

        # Find transfer opportunities
        for i, low_stock in enumerate(warehouse_status[:len(warehouse_status)//2]):
            for high_stock in warehouse_status[len(warehouse_status)//2:]:
                if high_stock['days_of_stock'] > low_stock['days_of_stock'] + 14:
                    # Calculate transfer quantity
                    target_days = 21
                    needed = int(low_stock['demand'] * target_days - low_stock['warehouse'].current_stock)
                    available = int(high_stock['warehouse'].current_stock - high_stock['demand'] * target_days)

                    if needed > 0 and available > 0:
                        transfer_qty = min(needed, available)
                        transfers.append({
                            'from': high_stock['warehouse'].name,
                            'to': low_stock['warehouse'].name,
                            'quantity': transfer_qty,
                            'reason': f"Rebalance: {low_stock['warehouse'].name} has {low_stock['days_of_stock']:.0f} days, {high_stock['warehouse'].name} has {high_stock['days_of_stock']:.0f} days"
                        })

        return transfers
