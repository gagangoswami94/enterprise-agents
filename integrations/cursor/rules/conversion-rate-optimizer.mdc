### A/B Test Framework
```python
import numpy as np
from scipy import stats
from dataclasses import dataclass
from typing import Optional, Tuple

@dataclass
class ExperimentConfig:
    name: str
    hypothesis: str
    primary_metric: str
    minimum_detectable_effect: float  # e.g., 0.05 for 5% lift
    baseline_rate: float  # e.g., 0.03 for 3% conversion
    significance_level: float = 0.05
    power: float = 0.80

@dataclass
class ExperimentResult:
    control_visitors: int
    control_conversions: int
    variant_visitors: int
    variant_conversions: int

    @property
    def control_rate(self) -> float:
        return self.control_conversions / self.control_visitors

    @property
    def variant_rate(self) -> float:
        return self.variant_conversions / self.variant_visitors

    @property
    def relative_lift(self) -> float:
        return (self.variant_rate - self.control_rate) / self.control_rate

class ABTestCalculator:
    """Statistical calculations for A/B testing"""

    def calculate_sample_size(self, config: ExperimentConfig) -> int:
        """Calculate required sample size per variant"""

        p1 = config.baseline_rate
        p2 = p1 * (1 + config.minimum_detectable_effect)

        # Pooled proportion
        p_pooled = (p1 + p2) / 2

        # Z-scores
        z_alpha = stats.norm.ppf(1 - config.significance_level / 2)
        z_beta = stats.norm.ppf(config.power)

        # Sample size formula
        n = (2 * p_pooled * (1 - p_pooled) * (z_alpha + z_beta) ** 2) / \
            (p1 - p2) ** 2

        return int(np.ceil(n))

    def analyze_results(self, result: ExperimentResult,
                       significance_level: float = 0.05) -> dict:
        """Analyze experiment results"""

        # Chi-square test
        contingency = [
            [result.control_conversions,
             result.control_visitors - result.control_conversions],
            [result.variant_conversions,
             result.variant_visitors - result.variant_conversions]
        ]
        chi2, p_value, dof, expected = stats.chi2_contingency(contingency)

        # Confidence interval for difference
        se = np.sqrt(
            result.control_rate * (1 - result.control_rate) / result.control_visitors +
            result.variant_rate * (1 - result.variant_rate) / result.variant_visitors
        )
        z = stats.norm.ppf(1 - significance_level / 2)
        diff = result.variant_rate - result.control_rate
        ci_lower = diff - z * se
        ci_upper = diff + z * se

        # Statistical significance
        is_significant = p_value < significance_level

        # Practical significance (typically want >5% lift)
        is_practically_significant = abs(result.relative_lift) > 0.05

        return {
            'control_rate': result.control_rate,
            'variant_rate': result.variant_rate,
            'absolute_difference': diff,
            'relative_lift': result.relative_lift,
            'p_value': p_value,
            'confidence_interval': (ci_lower, ci_upper),
            'is_statistically_significant': is_significant,
            'is_practically_significant': is_practically_significant,
            'recommendation': self._get_recommendation(
                is_significant, result.relative_lift, p_value
            )
        }

    def _get_recommendation(self, is_significant: bool,
                           lift: float, p_value: float) -> str:
        if not is_significant:
            if p_value < 0.1:
                return "Trending positive but not significant. Consider extending test."
            return "No significant difference. Consider new hypothesis."

        if lift > 0:
            if lift > 0.10:
                return "Strong winner! Implement variant immediately."
            return "Winner. Implement variant."
        else:
            return "Variant performed worse. Keep control."


class TestPrioritization:
    """Prioritize tests using ICE or PIE framework"""

    def score_ice(self, impact: int, confidence: int, ease: int) -> float:
        """ICE Score: Impact, Confidence, Ease (1-10 each)"""
        return (impact + confidence + ease) / 3

    def score_pie(self, potential: int, importance: int, ease: int) -> float:
        """PIE Score: Potential, Importance, Ease (1-10 each)"""
        return (potential + importance + ease) / 3

    def prioritize_tests(self, tests: list) -> list:
        """Sort tests by priority score"""
        for test in tests:
            test['score'] = self.score_ice(
                test['impact'],
                test['confidence'],
                test['ease']
            )
        return sorted(tests, key=lambda x: x['score'], reverse=True)
```

