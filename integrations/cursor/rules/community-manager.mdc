### Community Metrics Framework
```python
from dataclasses import dataclass
from datetime import datetime, timedelta
from typing import Dict, List

@dataclass
class CommunityMetrics:
    total_members: int
    active_members_30d: int
    new_members_30d: int
    churned_members_30d: int
    posts_30d: int
    replies_30d: int
    events_attended_30d: int
    nps_score: float

class CommunityHealthCalculator:
    """Calculate community health metrics"""

    def calculate_health_score(self, metrics: CommunityMetrics) -> Dict:
        """Calculate overall community health (0-100)"""

        scores = {}

        # Activity Rate (30%)
        activity_rate = metrics.active_members_30d / metrics.total_members
        scores['activity'] = min(activity_rate / 0.3, 1) * 100  # 30% active = 100

        # Growth Rate (20%)
        growth_rate = (metrics.new_members_30d - metrics.churned_members_30d) / \
                      max(metrics.total_members, 1)
        scores['growth'] = min(max(growth_rate / 0.05 + 0.5, 0), 1) * 100

        # Engagement Depth (25%)
        posts_per_active = metrics.posts_30d / max(metrics.active_members_30d, 1)
        replies_per_post = metrics.replies_30d / max(metrics.posts_30d, 1)
        scores['depth'] = min((posts_per_active / 2 + replies_per_post / 3) / 2, 1) * 100

        # Retention (15%)
        retention_rate = 1 - (metrics.churned_members_30d /
                            max(metrics.total_members - metrics.new_members_30d, 1))
        scores['retention'] = retention_rate * 100

        # Sentiment (10%)
        nps_normalized = (metrics.nps_score + 100) / 200  # -100 to 100 → 0 to 1
        scores['sentiment'] = nps_normalized * 100

        # Weighted total
        weights = {
            'activity': 0.30,
            'growth': 0.20,
            'depth': 0.25,
            'retention': 0.15,
            'sentiment': 0.10
        }

        total_score = sum(scores[k] * weights[k] for k in weights)

        return {
            'total_score': round(total_score, 1),
            'component_scores': scores,
            'health_status': self._get_status(total_score),
            'recommendations': self._get_recommendations(scores)
        }

    def _get_status(self, score: float) -> str:
        if score >= 80:
            return 'thriving'
        elif score >= 60:
            return 'healthy'
        elif score >= 40:
            return 'needs_attention'
        else:
            return 'at_risk'

    def _get_recommendations(self, scores: Dict) -> List[str]:
        recommendations = []

        if scores['activity'] < 60:
            recommendations.append(
                "Increase activity: Run engagement campaigns, add daily prompts"
            )
        if scores['growth'] < 50:
            recommendations.append(
                "Boost growth: Improve onboarding, activate referral program"
            )
        if scores['depth'] < 60:
            recommendations.append(
                "Deepen engagement: Create discussion series, spotlight members"
            )
        if scores['retention'] < 70:
            recommendations.append(
                "Improve retention: Survey churned members, enhance value prop"
            )
        if scores['sentiment'] < 60:
            recommendations.append(
                "Address sentiment: Gather feedback, address concerns publicly"
            )

        return recommendations
```

