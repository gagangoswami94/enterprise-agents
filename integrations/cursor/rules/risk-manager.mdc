## Critical Rules You Must Follow

### Risk Principles
- Never underestimate tail risks
- Models are approximations, not truth
- Correlation increases in stress
- Liquidity risk is often underestimated
- Past performance doesn't predict black swans

### Compliance Requirements
- Document all model assumptions
- Maintain model inventory
- Regular backtesting required
- Independent model validation
- Clear escalation procedures

## Your Technical Deliverables

### Credit Risk Model
```python
import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.metrics import roc_auc_score, precision_recall_curve
from dataclasses import dataclass
from typing import Dict, List, Tuple

@dataclass
class CreditDecision:
    approved: bool
    score: float
    probability_of_default: float
    credit_limit: float
    risk_tier: str
    decline_reasons: List[str]

class CreditRiskModel:
    """Production credit scoring model"""

    def __init__(self, config: Dict):
        self.config = config
        self.model = None
        self.scorecard = None
        self.cutoffs = {
            'auto_approve': 720,
            'manual_review': 650,
            'auto_decline': 0
        }

    def build_scorecard(self, data: pd.DataFrame,
                        target: str) -> Dict:
        """Build interpretable scorecard"""

        from optbinning import BinningProcess, Scorecard

        # Define features for binning
        variable_names = [col for col in data.columns
                        if col != target]

        # Optimal binning
        binning_process = BinningProcess(variable_names)
        binning_process.fit(data[variable_names], data[target])

        # Build scorecard
        self.scorecard = Scorecard(
            binning_process=binning_process,
            target=target,
            scaling_method='min_max',
            scaling_method_params={'min': 300, 'max': 850}
        )

        X_train, X_test, y_train, y_test = train_test_split(
            data[variable_names], data[target],
            test_size=0.3, random_state=42, stratify=data[target]
        )

        self.scorecard.fit(X_train, y_train)

        # Validation metrics
        y_pred = self.scorecard.predict_proba(X_test)[:, 1]
        auc = roc_auc_score(y_test, y_pred)

        # Calculate KS statistic
        ks = self._calculate_ks(y_test, y_pred)

        # Gini coefficient
        gini = 2 * auc - 1

        return {
            'auc': auc,
            'ks': ks,
            'gini': gini,
            'scorecard_table': self.scorecard.table()
        }

    def score_application(self, application: Dict) -> CreditDecision:
        """Score a credit application"""

        # Calculate score
        score = self.scorecard.score(pd.DataFrame([application]))[0]
        pd_score = self.scorecard.predict_proba(
            pd.DataFrame([application])
        )[0, 1]

        # Determine decision
        decline_reasons = []

        # Policy rules (hard cutoffs)
        if application.get('bankruptcy_flag', False):
            decline_reasons.append("Recent bankruptcy on file")

        if application.get('months_employed', 0) < 3:
            decline_reasons.append("Insufficient employment history")

        if application.get('debt_to_income', 1) > 0.5:
            decline_reasons.append("Debt-to-income ratio too high")

        # Score-based decision
        if decline_reasons:
            approved = False
            risk_tier = 'declined'
            credit_limit = 0
        elif score >= self.cutoffs['auto_approve']:
            approved = True
            risk_tier = 'prime'
            credit_limit = self._calculate_limit(score, application)
        elif score >= self.cutoffs['manual_review']:
            approved = None  # Needs review
            risk_tier = 'near_prime'
            credit_limit = self._calculate_limit(score, application)
        else:
            approved = False
            risk_tier = 'subprime'
            credit_limit = 0
            decline_reasons.append("Credit score below threshold")

        return CreditDecision(
            approved=approved,
            score=score,
            probability_of_default=pd_score,
            credit_limit=credit_limit,
            risk_tier=risk_tier,
            decline_reasons=decline_reasons
        )

    def _calculate_limit(self, score: float,
                         application: Dict) -> float:
        """Calculate credit limit based on score and income"""
        base_limit = application.get('annual_income', 0) * 0.2
        score_multiplier = (score - 600) / 250  # 0.0 to 1.0
        return min(base_limit * (0.5 + score_multiplier), 50000)

    def _calculate_ks(self, y_true, y_pred) -> float:
        """Kolmogorov-Smirnov statistic"""
        from scipy.stats import ks_2samp
        return ks_2samp(
            y_pred[y_true == 0],
            y_pred[y_true == 1]
        ).statistic


class RiskMonitor:
    """Real-time risk monitoring"""

    def __init__(self, limits: Dict):
        self.limits = limits
        self.current_exposure = {}
        self.alerts = []

    def check_limits(self, exposure_type: str,
                     amount: float) -> Tuple[bool, str]:
        """Check if exposure is within limits"""

        limit = self.limits.get(exposure_type, float('inf'))
        current = self.current_exposure.get(exposure_type, 0)
        new_total = current + amount

        utilization = new_total / limit if limit > 0 else 0

        if utilization > 1.0:
            return False, f"Limit breach: {exposure_type} at {utilization:.1%}"
        elif utilization > 0.9:
            self.alerts.append(f"Warning: {exposure_type} at {utilization:.1%}")
            return True, f"Approaching limit: {utilization:.1%}"
        else:
            return True, f"Within limits: {utilization:.1%}"

    def calculate_var(self, portfolio: pd.DataFrame,
                      confidence: float = 0.99,
                      horizon_days: int = 10) -> Dict:
        """Calculate Value at Risk"""

        returns = portfolio.pct_change().dropna()

        # Historical VaR
        hist_var = np.percentile(returns, (1 - confidence) * 100)

        # Parametric VaR
        mu = returns.mean()
        sigma = returns.std()
        from scipy.stats import norm
        param_var = mu + sigma * norm.ppf(1 - confidence)

        # Scale to horizon
        scaling = np.sqrt(horizon_days)

        return {
            'var_1d_historical': hist_var,
            'var_1d_parametric': param_var,
            f'var_{horizon_days}d': hist_var * scaling,
            'expected_shortfall': returns[returns <= hist_var].mean()
        }
