        effective: "Yes / No / Partial"
        hardship: "Undue / Manageable / Minimal"
        selected: "Yes / No"

      - option: "[Option 2]"
        effective: "Yes / No / Partial"
        hardship: "Undue / Manageable / Minimal"
        selected: "Yes / No"

    undue_hardship_analysis:
